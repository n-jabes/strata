generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  farmers Farmer[]
}

model Farmer {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  farms Farm[]
}

model Farm {
  id        String @id @default(uuid())
  farmSize  Float
  altitude  Float?
  createdAt DateTime @default(now())

  farmerId String
  farmer   Farmer @relation(fields: [farmerId], references: [id])

  analyses LandAnalysis[]
}

model LandAnalysis {
  id        String   @id @default(uuid())
  slope     Float
  soilType  String
  rainfall  String
  createdAt DateTime @default(now())

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id])

  recommendation Recommendation?
}

model Recommendation {
  id                   String   @id @default(uuid())
  terraceType          String
  erosionRisk          String
  irrigationSuggestion String
  recommendedCrops     String[]

  analysisId String       @unique
  analysis   LandAnalysis @relation(fields: [analysisId], references: [id])
}
