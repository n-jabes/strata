generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String             @id @default(uuid())
  name            String
  email           String             @unique
  password        String
  location        String?
  bio             String?
  profilePicture  String?
  farmSize        Float?
  soilType        String?
  experienceLevel ExperienceLevel?
  createdAt       DateTime           @default(now())

  farms        Farm[]
  posts        Post[]
  postLikes    PostLike[]
  postComments PostComment[]
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Farm {
  id        String   @id @default(uuid())
  name      String
  location  String
  size      Float
  altitude  Float?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  analyses LandAnalysis[]
}

model LandAnalysis {
  id        String   @id @default(uuid())
  slope     Float
  soilType  String
  rainfall  String
  createdAt DateTime @default(now())

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id])

  recommendation Recommendation?
}

model Recommendation {
  id                   String   @id @default(uuid())
  terraceType          String
  erosionRisk          String
  irrigationSuggestion String
  recommendedCrops     String[]

  analysisId String       @unique
  analysis   LandAnalysis @relation(fields: [analysisId], references: [id])
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
}

enum PostCategory {
  TIP
  GUIDE
  QUESTION
  EXPERIENCE
}

model Post {
  id          String       @id @default(uuid())
  title       String
  description String
  type        PostType
  mediaUrl    String?
  hashtags    String[]
  category    PostCategory
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  comments PostComment[]
  likes    PostLike[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model PostComment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentCommentId String?
  parentComment   PostComment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies PostComment[] @relation("CommentReplies")

  @@index([postId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([postId, parentCommentId, createdAt(sort: Desc)])
}

model PostLike {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}
